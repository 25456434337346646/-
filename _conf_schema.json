{
    "text_api_url": {
        "description": "逻辑大脑（文本）接口地址",
        "type": "string",
        "hint": "用于文本生成的接口地址，例如 https://api.deepseek.com/v1",
        "default": "https://api.deepseek.com/v1"
    },
    "text_api_key": {
        "description": "逻辑大脑（文本）API Key",
        "type": "string",
        "hint": "用于逻辑分析模型的 API 密钥",
        "obvious_hint": true,
        "default": ""
    },
    "ocr_api_url": {
        "description": "视觉解析（OCR）接口地址",
        "type": "string",
        "hint": "用于图片识别的接口地址，需支持 Vision，例如 https://api.deepseek.com/v1",
        "default": "https://api.deepseek.com/v1"
    },
    "ocr_api_key": {
        "description": "视觉解析（OCR）API Key",
        "type": "string",
        "hint": "用于视觉识别模型的 API 密钥",
        "obvious_hint": true,
        "default": ""
    },
    "llm_model": {
        "description": "逻辑大脑模型名称",
        "type": "string",
        "hint": "文本对话模型，例如 deepseek-chat",
        "default": "deepseek-chat"
    },
    "llm_vision_model": {
        "description": "视觉识别模型名称",
        "type": "string",
        "hint": "多模态模型，例如 qwen-vl-max 或 gpt-4o",
        "default": "qwen-vl-max"
    },
    "delay_between_chat": {
        "description": "交互时延",
        "type": "float",
        "hint": "消息发送间隔（秒）",
        "default": 1.5
    }
}